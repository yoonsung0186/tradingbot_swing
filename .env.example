# Alpaca paper trading credentials.
# Create these in your Alpaca dashboard, then copy this file to .env.
ALPACA_KEY_ID=your_key_id_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Official research and macro data providers.
SEC_USER_AGENT=ys-ai-trading-agent your_email@example.com
SEC_API_BASE_URL=https://data.sec.gov
FRED_API_KEY=your_fred_api_key
FRED_API_BASE_URL=https://api.stlouisfed.org/fred

# Live trading is disabled unless this is explicitly set to true.
# Only use with a real Alpaca live account after paper testing.
ALPACA_LIVE_TRADING_ENABLED=false
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Local paper simulation defaults.
TRADING_AGENT_STARTING_CASH=10000
TRADING_AGENT_STATE_FILE=data/paper_state.json
